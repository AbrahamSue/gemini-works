#!/bin/bash
#
# Remote JS Evaluator for Microsoft Edge (CDP)
# Uses /x/sbin/main.sh framework
# Supports shebang usage: #!/path/to/rdp_exec [options] -f
# Supports in-file config: #host=192.168.0.252 #port=9222 #url=... #clean
#
. /x/sbin/main.sh

# defaults
: ${inHost:="192.168.0.252"}
: ${inPort:="9222"}
: ${inFile:=}
: ${inURL:=}
: ${inClean:=}

# Target selection logic
get_target_ws() {
    local remote_url="http://${inHost}:${inPort}"
    
    # 1. Fetch current tabs
    local json_data=$(curl -s "${remote_url}/json")
    if [ -z "$json_data" ]; then
        log "[ERROR] No response from ${remote_url}. Check if Edge is running with --remote-debugging-port."
        return 1
    fi

    # 2. Prefer the active/focused page or the first one
    local ws_url=$(echo "$json_data" | jq -r '
        map(select(.type == "page")) | 
        if length > 0 then .[0].webSocketDebuggerUrl else empty end
    ')

    if [ -z "$ws_url" ] || [ "$ws_url" == "null" ]; then
        log "[ERROR] Could not find an active page WebSocket URL."
        return 1
    fi
    
    echo "$ws_url"
}

# Core evaluation function
process_eval() {
    # If using inProcessAll, inFile should already be set by -f in shebang.
    # Any remaining arguments in $@ are passed to the JS.
    
    # Pre-parse: If first arg is a file and inFile not set, it's the script
    if [ -z "$inFile" ] && [ -f "$1" ]; then
        inFile="$1"
        shift
    fi

    # If inFile is still not set, we can't continue
    if [ -z "$inFile" ]; then
        log "[ERROR] No script file specified. Use -f or provide a file path."
        return 1
    fi

    # Parse in-file configurations
    if [ -f "$inFile" ]; then
        while read -r line; do
            [[ "$line" =~ ^#!/ ]] && continue
            if [[ "$line" =~ ^#([a-zA-Z]+)=(.*)$ ]]; then
                key="${BASH_REMATCH[1]}"
                val="${BASH_REMATCH[2]}"
                val="${val%\"}"
                val="${val#\"}"
                case "$key" in
                    host) [ "$inHost" = "192.168.0.252" ] && inHost="$val" ;;
                    port) [ "$inPort" = "9222" ] && inPort="$val" ;;
                    url)  [ -z "$inURL" ] && inURL="$val" ;;
                esac
            elif [[ "$line" =~ ^#clean$ ]]; then
                inClean=y
            elif [[ "$line" =~ ^[[:space:]]*$ ]]; then
                continue
            elif [[ ! "$line" =~ ^# ]]; then
                break
            fi
        done < "$inFile"
    fi

    # Dynamic URL: If a positional arg looks like a URL and inURL is empty, use it
    for arg in "$@"; do
        if [[ "$arg" =~ ^https?:// ]] && [ -z "$inURL" ]; then
            inURL="$arg"
            log "[INFO] Using URL from command line: $inURL"
            break
        fi
    done

    local remote_url="http://${inHost}:${inPort}"
    local target_id=""
    local ws_url=""

    # Handle initial URL
    if [ -n "$inURL" ]; then
        log "[INFO] Creating new tab for: $inURL"
        local new_tab_json=$(curl -s -X PUT "${remote_url}/json/new?${inURL}")
        target_id=$(echo "$new_tab_json" | jq -r '.id')
        ws_url=$(echo "$new_tab_json" | jq -r '.webSocketDebuggerUrl')
        
        if [ -z "$target_id" ] || [ "$target_id" == "null" ]; then
            log "[ERROR] Failed to create new tab. Is the remote host/port correct?"
            return 1
        fi
        sleep 2
    fi

    if [ -z "$ws_url" ]; then
        ws_url=$(get_target_ws)
        [ $? -ne 0 ] && return 1
        target_id=$(echo "$ws_url" | sed -re 's/^.*\/page\///')
    fi

    # Read JS and build JSON payload
    # Robustly strip ALL leading comments and shebangs until the first non-comment line
    local js_content=$(sed -e '/^#!/d' -e '/^#/d' -e '/./,$!d' "$inFile")
    
    # Inject ARGV into the script
    local argv_json=$(jq -n '$ARGS.positional' --args "$@")
    local final_js="const ARGV = ${argv_json}; ${js_content}"

    local payload=$(jq -n -c --arg expr "$final_js" '
        {
            id: 1, 
            method: "Runtime.evaluate", 
            params: {
                expression: $expr, 
                returnByValue: true,
                awaitPromise: true
            }
        }
    ')

    log "[INFO] Evaluating script from '$inFile' on $ws_url..."
    [ -n "$inVerbose" ] && log "[DEBUG] ARGV: $argv_json"
    
    local result=$(printf "%s\n" "$payload" | websocat -n1 -B 1000000 "$ws_url")
    
    if [ -n "$inVerbose" ]; then
        echo "$result" | jq '.'
    else
        local val=$(echo "$result" | jq -r '.result.result.value // empty')
        if [ -n "$val" ]; then
            if echo "$val" | jq -e . >/dev/null 2>&1; then
                echo "$val" | jq '.'
            else
                echo "$val"
            fi
        else
            echo "$result" | jq -r '.result.exceptionDetails.exception.description // .error.message // "Execution complete (no return value)"'
        fi
    fi

    if [ -n "$inClean" ] && [ -n "$target_id" ]; then
        log "[INFO] Closing tab: $target_id"
        curl -s "${remote_url}/json/close/${target_id}" > /dev/null
    fi
}

# Fix for shebang argument splitting on Linux
if [ $# -ge 1 ] && [[ "$1" == *" "* ]]; then
    eval set -- "$1" "${@:2}"
fi

# Entry point using main.sh main()
main -* process_eval 1.4.1 '
  -f|--file)        inFile="$2"; shift; ;;          # JavaScript file to evaluate
  -u|--url)         inURL="$2"; shift; ;;           # Initial URL to load on remote
  -C|--clean)       inClean=y; ;;                   # Close the tab after evaluation
  -d|--debug)       inDebug=y; ;;                   # Enable debug mode
  -p|--port)        inPort="$2"; shift; ;;          # Override remote port (default: 9222)
  -H|--host)        inHost="$2"; shift; ;;          # Override remote host (default: 192.168.0.252)
' "$@"
